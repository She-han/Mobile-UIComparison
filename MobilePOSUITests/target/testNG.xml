<!DOCTYPE suite SYSTEM "http://testng.org/testng-1.0.dtd" >
<suite name="Pos test">
	<parameter name="showProgress" value="true" />
	<test name="feature.sale" junit="false">
	<parameter name="featurePaths" value="target/dependencyTests/feature/retail/pos" />
	<!-- com.enactor.pos.mobile.visual is on the glue path so the visual-regression @After hook is
	     discovered. The hook is inert unless VisualRegression.FailScenarioOnUnmatch=true. -->
	<parameter name="gluePaths" value="com.enactor.retail.pos.stepDefinitions,com.enactor.pos.mobile.visual" />
		<classes>
			<class name="com.enactor.core.automation.cucumber.RunCucumberTests" />	
		</classes>
	</test>

</suite>