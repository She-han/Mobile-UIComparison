<?xml version="1.0" encoding="UTF-8"?>
<assembly
	xmlns="http://maven.apache.org/plugins/maven-assembly-plugin/assembly/1.1.2"
	xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
	xsi:schemaLocation="
    http://maven.apache.org/plugins/maven-assembly-plugin/assembly/1.1.2
      http://maven.apache.org/xsd/assembly-1.1.2.xsd">
	<id>deploy</id>	
	<baseDirectory></baseDirectory>
	<formats>
		<format>zip</format>
	</formats>
	
	<files>
		<file>
			<source>deploy-pom.xml</source>
			<destName>pom.xml</destName>
		</file>
		<file>
			<source>testNG.xml</source>
		</file>
		<file>
			<source>test/posNextGen1024x768.properties</source>
			<outputDirectory>test/</outputDirectory>
		</file>
		<file>
			<source>test/deployTestData.properties</source>
			<destName>testData.properties</destName>
			<outputDirectory>test/</outputDirectory>
		</file>
		<file>
		    <source>test/deployTestData.properties</source>
            <destName>posSelfCheckout.properties</destName>
            <outputDirectory>test/</outputDirectory>
        </file>
	</files>
	
	<fileSets>
		<fileSet>
			<directory>src/com/enactor/pos</directory>
			<outputDirectory>src/com/enactor/pos</outputDirectory>
		</fileSet>
		<fileSet>
			<directory>test/feature/retail/pos</directory>
			<outputDirectory>test/feature/retail/pos</outputDirectory>
		</fileSet>
		<fileSet>
			<directory>test/com/enactor/retail/pos</directory>
			<outputDirectory>test/com/enactor/retail/pos</outputDirectory>
		</fileSet>
	</fileSets>
	
	<dependencySets>
        <dependencySet>
            <outputDirectory>/lib</outputDirectory>
            <unpack>false</unpack>
            <excludes>
                <exclude>${artifact}</exclude>
            </excludes>
        </dependencySet>
    </dependencySets>
</assembly>
