{
	"info": {
		"_postman_id": "b99246df-2eb8-4f87-a143-e4dfb6373b44",
		"name": "Test Basket Postman Scripts",
		"schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json",
		"_exporter_id": "30482787"
	},
	"item": [
		{
			"name": "Create Basket",
			"item": [
				{
					"name": "Create Basket  - Success",
					"event": [
						{
							"listen": "prerequest",
							"script": {
								"exec": [
									"pm.environment.set(\"basketName\", _.random(1001, 9999999));"
								],
								"type": "text/javascript",
								"packages": {}
							}
						},
						{
							"listen": "test",
							"script": {
								"exec": [
									"pm.test(\"Status code is 201\", function () {\r",
									"    pm.response.to.have.status(201);\r",
									"});\r",
									"\r",
									"pm.test(\"should have basket reference in location header field\", function () {\r",
									"    pm.expect(pm.response.headers.get(\"Location\")).to.contain(pm.environment.get(\"basketReference\"));\r",
									"});"
								],
								"type": "text/javascript",
								"packages": {}
							}
						}
					],
					"request": {
						"auth": {
							"type": "noauth"
						},
						"method": "POST",
						"header": [
							{
								"key": "content-type",
								"value": "application/json"
							},
							{
								"key": "Subject",
								"value": "5555",
								"disabled": true
							}
						],
						"body": {
							"mode": "raw",
							"raw": "{\n    \"basketName\": \"{{basketName}}\",\n    \"basketType\": \"BASKET\",\n    \"basketReference\": \"{{basketReference}}\",\n    \"forOrder\": false,\n    \"deviceId\": \"{{deviceId}}\",\n    \"customerDetails\": {\n        \"name\": {\n            \"forename\": \"{{customerForename}}\",\n            \"surname\": \"{{customerSurname}}\",\n            \"title\": \"{{customerTitle}}\",\n            \"dateOfBirth\": \"{{customerDateOfBirth}}\"\n        },\n        \"emailAddress\": {\n            \"emailAddress\": \"{{customerEmailAddress}}\"\n        },\n        \"phoneNumber\": {\n            \"number\": \"{{customerNumber}}\"\n        }\n    }\n}",
							"options": {
								"raw": {
									"language": "json"
								}
							}
						},
						"url": {
							"raw": "{{restapi.base.url}}/WebRestApi/rest/baskets/",
							"host": [
								"{{restapi.base.url}}"
							],
							"path": [
								"WebRestApi",
								"rest",
								"baskets",
								""
							]
						}
					},
					"response": []
				},
				{
					"name": "Create Basket Item  - Success",
					"event": [
						{
							"listen": "prerequest",
							"script": {
								"exec": [
									""
								],
								"type": "text/javascript",
								"packages": {}
							}
						},
						{
							"listen": "test",
							"script": {
								"exec": [
									"pm.test(\"Status code is 201\", function () {\r",
									"    pm.response.to.have.status(200);\r",
									"});\r",
									"\r",
									""
								],
								"type": "text/javascript",
								"packages": {}
							}
						}
					],
					"request": {
						"auth": {
							"type": "noauth"
						},
						"method": "POST",
						"header": [
							{
								"key": "content-type",
								"value": "application/json"
							},
							{
								"key": "Subject",
								"value": "5555",
								"disabled": true
							}
						],
						"body": {
							"mode": "raw",
							"raw": "{\n  \"itemId\" : \"{{product1_Id}}\",\n  \"itemType\" : \"PRODUCT\",\n  \"forOrder\" : false\n}",
							"options": {
								"raw": {
									"language": "json"
								}
							}
						},
						"url": {
							"raw": "{{restapi.base.url}}/WebRestApi/rest/baskets/{{basketReference}}/items",
							"host": [
								"{{restapi.base.url}}"
							],
							"path": [
								"WebRestApi",
								"rest",
								"baskets",
								"{{basketReference}}",
								"items"
							]
						}
					},
					"response": []
				}
			]
		}
	]
}